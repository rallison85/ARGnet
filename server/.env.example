# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database
DATABASE_PATH=./data/argnet.db

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
